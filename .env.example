# API server (server/index.ts) — do not commit real keys
OPENAI_API_KEY=

# --- Optional: lock `/api/*` behind auth (recommended when OPENAI_API_KEY is set on the server)
# At least one of password login or bearer token:
# AUTH_SECRET must be ≥32 chars (used to sign session cookies).
# AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars
# AUTH_PASSWORD=your-shared-password-at-least-8-chars
# Optional: machine token (curl/scripts): Authorization: Bearer <token>
# API_AUTH_TOKEN=
# HTTPS deployments: set so browsers send cookies cross-site when UI and API share parent domain
# AUTH_COOKIE_SECURE=1
# Optional: override default gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# Optional: embeddings for AppRetrieve cosine (default text-embedding-3-small)
# OPENAI_EMBED_MODEL=text-embedding-3-small
# Vite: optional; must match OPENAI_EMBED_MODEL so client-side embed cache keys stay valid
# VITE_OPENAI_EMBED_MODEL=text-embedding-3-small
# PORT=8787

# Comma- or space-separated list of **browser** origins allowed to call the API (CORS).
# In production, set to your static site origin(s), e.g. https://your-app.vercel.app
# If unset, localhost / 127.0.0.1 (ports 5173, 4173) are used for local dev.
# CORS_ORIGINS=https://your-app.vercel.app

# Vite: only used at **build** time. Set the public **API** origin (no path) when the UI
# and API are on different hosts, e.g. https://flow-prompt-api.onrender.com
# Leave empty for local dev (same-origin /api via Vite proxy).
# VITE_API_ORIGIN=https://your-api.onrender.com

# --- Stage B: Postgres (optional). After `docker compose up -d` and `npm run db:migrate`:
# DATABASE_URL=postgresql://flow:flow@127.0.0.1:5433/flow_prompt
# Skip background embedding after corpus writes (tests or cost control). Manual POST /api/corpora/:id/embed still works.
# SKIP_AUTO_EMBED=1
# Build-time flags (see README "Server persistence"):
# VITE_SYNC_SERVER=1
# VITE_SERVER_COSINE_RETRIEVE=1
# VITE_COSINE_CLIENT_FALLBACK=1  # only if you want in-browser cosine when /api/retrieve fails
# VITE_NO_CLIENT_EMBED_IDB=1     # optional; VITE_SYNC_SERVER=1 already skips flow-prompt-embed-v1
