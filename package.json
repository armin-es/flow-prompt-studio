{
  "name": "flow-prompt-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n client,api -c blue,magenta \"wait-on tcp:127.0.0.1:8787 && vite\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:client-only": "vite",
    "build": "tsc -b && vite build",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "tsx server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:up": "docker compose up -d",
    "db:migrate": "npm run db:up && node scripts/waitForDb.mjs && drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "npm run db:up && node scripts/waitForDb.mjs && drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.40.0",
    "hono": "^4.11.1",
    "jose": "^6.2.3",
    "openai": "^6.16.0",
    "pg": "^8.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.1"
  }
}
