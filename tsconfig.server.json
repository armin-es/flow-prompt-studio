{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "server/**/*.ts",
    "src/engine/retrieve/chunk.ts",
    "src/engine/retrieve/formatRetrieveOutput.ts",
    "src/engine/topologicalSort.ts",
    "src/engine/spamPasteSource.ts",
    "src/lib/normalizeGraphNode.ts",
    "src/lib/spamJudgeResult.ts",
    "src/types/index.ts"
  ]
}
